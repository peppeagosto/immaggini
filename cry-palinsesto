<!DOCTYPE html>
<html lang="el">
<head>
<meta charset="UTF-8">
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<style>
    :root { 
        --rb: linear-gradient(to right, #f00, #ff0, #0f0, #0ff, #f0f, #f00); 
    }
    
    body { 
        background: transparent; 
        margin: 0; 
        height: 1000px; 
        width: 100%; 
        font-family: 'Arial Black', sans-serif; 
        overflow: hidden; 
        pointer-events: none; 
    }

    /* TASTO APERTURA */
    #btn-pali {
        position: fixed;
        right: 20px;
        top: 60px;
        width: 150px;
        height: 55px;
        background: #000;
        border: 2px solid #fff;
        border-radius: 8px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 999999 !important;
        box-shadow: 0 0 15px rgba(255,255,255,0.3);
        transition: 0.3s;
        pointer-events: auto;
    }
    
    #btn-pali:hover { border-color: #f00; transform: scale(1.05); }
    
    .btn-text {
        background: var(--rb);
        -webkit-background-clip: text;
        color: transparent;
        font-size: 11px;
        font-weight: 900;
        text-transform: uppercase;
    }

    /* LOCANDINA */
    #locandina {
        display: none;
        position: fixed;
        right: 10px;
        top: 150px; 
        width: 230px;
        background: #000;
        border: 3px solid #333;
        border-radius: 12px;
        padding: 10px;
        box-shadow: 0 0 50px #000;
        z-index: 999998 !important;
        pointer-events: auto;
    }

    .header { text-align: center; border-bottom: 2px solid #222; margin-bottom: 12px; padding-bottom: 8px; }
    .titolo { background: var(--rb); -webkit-background-clip: text; color: transparent; font-size: 13px; font-weight: 900; }

    .slot { 
        background: #0a0a0a; border: 1px solid #222; border-radius: 30px; 
        margin-bottom: 6px; padding: 4px; display: flex; align-items: center; gap: 8px; 
    }
    .info-box { display: flex; flex-direction: column; flex-grow: 1; }
    .ora { color: #0ff; font-size: 9px; font-weight: bold; width: 40px; text-align: center; }
    .foto { width: 35px; height: 35px; border-radius: 50%; border: 1px solid #fff; object-fit: cover; }
    .nome { color: #ff4d6d; font-size: 9px; text-transform: uppercase; font-weight: 900; }
</style>
</head>
<body>

    <div id="btn-pali">
        <div class="btn-text">ΟΙ DJ ΜΟΥ</div> 
        <div style="color:yellow; font-size:9px;">ΠΡΟΓΡΑΜΜΑ</div>
    </div>

    <div id="locandina">
        <div class="header">
            <div class="titolo">ΠΡΟΓΡΑΜΜΑ DJ 7/7</div> 
        </div>
        <div id="lista-dj">
            </div>
    </div>

<script>
    // 1. Lista originale delle DJ
    const djSquad = [
        { n: "ROSALIA", f: "https://xatimg.com/image/2gSKS392WGsA.jpg" },
        { n: "MANUELA", f: "https://xatimg.com/image/TIRy1ncyBLxs.jpg" },
        { n: "LUNA", f: "https://xatimg.com/image/o9IvXbicXLLE.jpg" },
        { n: "AURORA", f: "https://xatimg.com/image/zYqnr0Jjlv7u.jpg" },
        { n: "VALENTINA", f: "https://xatimg.com/image/x0gkWvMK3nvh.jpg" },
        { n: "GIADA", f: "https://xatimg.com/image/q6LHVczfFBeZ.jpg" },
        { n: "ELISA", f: "https://xatimg.com/image/xseLcaaxCvVJ.jpg" }
    ];

    // 2. Orari fissi (si assegnano in ordine dopo il rimescolamento)
    const orari = ["14:00", "15:00", "16:00", "17:00", "18:00", "19:00", "20:00"];

    // 3. Funzione per rimescolare in base alla data (Zero manutenzione)
    function shuffleByDate(array) {
        const date = new Date();
        // Usiamo giorno + mese come seme per il rimescolamento
        let seed = date.getDate() + date.getMonth(); 
        let currentIndex = array.length, temporaryValue, randomIndex;

        while (0 !== currentIndex) {
            // Generatore di numeri "casuali" ma fissi per oggi
            seed = (seed * 9301 + 49297) % 233280;
            randomIndex = Math.floor((seed / 233280) * currentIndex);
            currentIndex -= 1;
            temporaryValue = array[currentIndex];
            array[currentIndex] = array[randomIndex];
            array[randomIndex] = temporaryValue;
        }
        return array;
    }

    function generaPalinsesto() {
        const container = $('#lista-dj');
        // Rimescoliamo una copia della lista
        const rimescolate = shuffleByDate([...djSquad]);

        rimescolate.forEach((dj, index) => {
            const html = `
                <div class="slot">
                    <span class="ora">${orari[index]}</span>
                    <img class="foto" src="${dj.f}">
                    <div class="info-box">
                        <span class="nome">${dj.n}</span>
                    </div>
                </div>`;
            container.append(html);
        });
    }

    // Gestione apertura locandina
    document.getElementById('btn-pali').onclick = function() {
        var loc = document.getElementById('locandina');
        loc.style.display = (loc.style.display === "block") ? "none" : "block";
    };

    window.onload = generaPalinsesto;
</script>
</body>
</html>
